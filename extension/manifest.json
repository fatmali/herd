{
  "manifest_version": 3,
  "name": "Herd - Tab Organizer",
  "version": "0.2.0",
  "key": "",
  "description": "Organize tabs into herds. Search, recover context, and never lose where you were.",
  "permissions": ["tabs", "tabGroups", "alarms", "storage", "contextMenus", "nativeMessaging", "scripting", "activeTab"],
  "optional_permissions": ["notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Herd - Organize Tabs"
  },
  "commands": {
    "open-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Search across all open tabs"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
